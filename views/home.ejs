    <script>
      function handleGoogleSignIn(response) {
        fetch("/api/auth/google", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ idToken: response.credential }),
        })
          .then((r) => r.json())
          .then((data) => {
            if (data.error) return alert(data.error);
            localStorage.setItem("token", data.token);
            bootstrap.Modal.getInstance(
              document.getElementById("authModal"),
            ).hide();
            onAuthSuccess(data.user);
          })
          .catch(() => alert("Google sign in failed."));
      }

      // ══════════ AUTH ══════════

      function requireAuth() {
        if (localStorage.getItem("token")) return true;
        bootstrap.Modal.getOrCreateInstance(
          document.getElementById("authModal"),
        ).show();
        return false;
      }

      // Block post modal if not logged in
      document
        .getElementById("postModal")
        .addEventListener("show.bs.modal", (e) => {
          if (!requireAuth()) e.preventDefault();
        });

      function switchTab(tab) {
        const isSignIn = tab === "signin";
        document
          .getElementById("panelSignIn")
          .classList.toggle("hidden", !isSignIn);
        document
          .getElementById("panelSignUp")
          .classList.toggle("hidden", isSignIn);
        document
          .getElementById("tabSignIn")
          .classList.toggle("active", isSignIn);
        document
          .getElementById("tabSignUp")
          .classList.toggle("active", !isSignIn);
      }

      // Sign In
      document
        .querySelector("#panelSignIn .btn-primary")
        .addEventListener("click", async () => {
          const email = document.getElementById("siEmail").value.trim();
          const password = document.getElementById("siPassword").value;
          if (!email || !password) return alert("Please fill in all fields.");

          try {
            const res = await fetch("/api/auth/signin", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ email, password }),
            });
            const data = await res.json();
            if (!res.ok) return alert(data.error);
            localStorage.setItem("token", data.token);
            bootstrap.Modal.getInstance(
              document.getElementById("authModal"),
            ).hide();
            onAuthSuccess(data.user);
          } catch {
            alert("Something went wrong. Please try again.");
          }
        });

      // Sign Up
      document
        .querySelector("#panelSignUp .btn-primary")
        .addEventListener("click", async () => {
          const email = document.getElementById("suEmail").value.trim();
          const password = document.getElementById("suPassword").value;
          if (!email || !password) return alert("Please fill in all fields.");

          try {
            const res = await fetch("/api/auth/signup", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ email, password }),
            });
            const data = await res.json();
            if (!res.ok) return alert(data.error);
            localStorage.setItem("token", data.token);
            bootstrap.Modal.getInstance(
              document.getElementById("authModal"),
            ).hide();
            onAuthSuccess(data.user);
          } catch {
            alert("Something went wrong. Please try again.");
          }
        });

      function onAuthSuccess(user) {
          console.log("onAuthSuccess token:", localStorage.getItem("token")); // ✅
        document.querySelectorAll(".avatar").forEach((el) => {
          el.textContent = user.email[0].toUpperCase();
        });



      const headerBtns = document.querySelector(".app-header .d-flex");
  headerBtns.innerHTML = `
    <button class="btn btn-sm btn-outline-danger rounded-3" onclick="signOut()">
      <i class="bi bi-box-arrow-right me-1"></i>Sign Out
    </button>
  `;
    setTimeout(() => loadPosts(), 100); // ✅ small delay to ensure token is set
}

      function signOut() {
        localStorage.removeItem("token");
        location.reload();
      }

      // Restore UI on page load if already logged in
  (function init() {
  const token = localStorage.getItem("token");
  if (!token) return;
  try {
    const payload = JSON.parse(atob(token.split(".")[1]));
    if (payload.exp * 1000 < Date.now())
      return localStorage.removeItem("token");
    onAuthSuccess({ email: payload.email }); // ✅ this will call loadPosts() again after 100ms
  } catch {
    localStorage.removeItem("token");
  }
})();

      // ══════════ POST FORM ══════════

      const imageInput = document.getElementById("imageInput");
      const imagePreview = document.getElementById("imagePreview");
      const previewWrap = document.getElementById("previewWrapper");
      const uploadZone = document.getElementById("uploadZone");
      const removeBtn = document.getElementById("removeBtn");
      const captionInput = document.getElementById("captionInput");
      const charCount = document.getElementById("charCount");
      const postBtn = document.getElementById("postBtn");
      const postForm = document.getElementById("postForm");
      const feed = document.getElementById("feed");

      function checkReady() {
        postBtn.disabled = !(
          imageInput.files.length || captionInput.value.trim()
        );
      }

      function showPreview(file) {
        if (!file) return;
        imagePreview.src = URL.createObjectURL(file);
        previewWrap.classList.remove("d-none");
        uploadZone.classList.add("d-none");
        checkReady();
      }

      function clearImage() {
        imagePreview.src = "";
        previewWrap.classList.add("d-none");
        uploadZone.classList.remove("d-none");
        imageInput.value = "";
        checkReady();
      }

      imageInput.addEventListener("change", (e) =>
        showPreview(e.target.files[0]),
      );
      removeBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        clearImage();
      });

      uploadZone.addEventListener("dragover", (e) => {
        e.preventDefault();
        uploadZone.style.borderColor = "#0d6efd";
        uploadZone.style.background = "#f0f4ff";
      });
      uploadZone.addEventListener("dragleave", () => {
        uploadZone.style.borderColor = "";
        uploadZone.style.background = "";
      });
      uploadZone.addEventListener("drop", (e) => {
        e.preventDefault();
        uploadZone.style.borderColor = "";
        uploadZone.style.background = "";
        const f = e.dataTransfer.files[0];
        if (f?.type.startsWith("image/")) {
          const dt = new DataTransfer();
          dt.items.add(f);
          imageInput.files = dt.files;
          showPreview(f);
        }
      });

      captionInput.addEventListener("input", () => {
        // const l = captionInput.value.length;
        // charCount.textContent = `${l} / 300`;
        // charCount.style.color =
        //   l >= 300 ? "#dc3545" : l >= 250 ? "#f0ad4e" : "";
        checkReady();
      });

   // Submit Post (with auth token)
postForm.addEventListener("submit", async (e) => {
  e.preventDefault();
  postBtn.innerHTML =
    '<span class="spinner-border spinner-border-sm me-1"></span>Posting...';
  postBtn.disabled = true;

  const formData = new FormData(postForm);
  const token = localStorage.getItem("token");

  // ✅ Append optional fields only if filled in
  const pictureLocation = document.getElementById("pictureLocation-input").value.trim();
  const location = document.getElementById("location-input").value.trim();
  if (pictureLocation) formData.append("pictureLocation", pictureLocation);
  if (location) formData.append("location", location);

  try {
    const res = await fetch("/create-post", {
      method: "POST",
      headers: { Authorization: `Bearer ${token}` },
      body: formData,
    });
    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.error);
    }

    postBtn.innerHTML = '<i class="bi bi-check-circle me-1"></i>Posted!';
    setTimeout(() => {
      bootstrap.Modal.getInstance(
        document.getElementById("postModal"),
      ).hide();
      postBtn.innerHTML = '<i class="bi bi-send me-1"></i>Post';
      clearImage();
      captionInput.value = "";
      // charCount.textContent = "0 / 300";
      // ✅ Clear the two new fields on reset
      document.getElementById("pictureLocation-input").value = "";
      document.getElementById("location-input").value = "";
      loadPosts();
    }, 1200);
  } catch (err) {
    alert(err.message);
    postBtn.innerHTML = '<i class="bi bi-send me-1"></i> Post ';
    checkReady();
  }
});

function renderPost(post) {
  const template = document.getElementById("post-template");
  const card = template.content.cloneNode(true);

  const body        = card.querySelector(".post-body");
  const img         = card.querySelector(".post-image");
  const picHeading  = card.querySelector(".post-picture-location");
  const locPara     = card.querySelector(".post-location");
  const locWrapper  = card.querySelector(".post-location-wrapper");
  const postOptions = card.querySelector(".post-options");
  const deleteBtn   = card.querySelector(".delete-btn");
  const polaroid    = card.querySelector(".polaroid");

  // Picture location heading
  post.pictureLocation
    ? (picHeading.textContent = `This picture was taken at ${post.pictureLocation}`)
    : picHeading.remove();

  post.caption ? (body.textContent = post.caption) : body.remove();
  post.imageUrl ? (img.src = post.imageUrl) : img.remove();

  // Location link
  post.location
    ? (locPara.href = `https://www.google.com/maps/search/${encodeURIComponent(post.location)}`,
       locPara.textContent = `📍 ${post.location}`,
       locWrapper.classList.remove("d-none"))
    : locWrapper.remove();

  // ✅ Show delete button only to post owner
  const token = localStorage.getItem("token");
  if (token) {
    try {
      const payload = JSON.parse(atob(token.split(".")[1]));
      const userId = payload.id || payload._id || payload.userId;

      console.log("userId from token:", userId);
      console.log("post.user:", post.user);

      if (String(userId) === String(post.user)) {
        postOptions.classList.remove("d-none");

        // ✅ Delete button click handler
        deleteBtn.addEventListener("click", async () => {
          console.log("🔴 delete button clicked");

          if (!confirm("Are you sure you want to delete this post?")) return;

          console.log("🟡 confirmed, post._id:", post._id);
          console.log("🟡 token:", token);

          try {
            const res = await fetch(`/posts/${post._id}`, {
              method: "DELETE",
              headers: { Authorization: `Bearer ${token}` },
            });
            console.log("🟢 response status:", res.status);
            if (!res.ok) {
              const err = await res.json();
              throw new Error(err.error);
            }
            polaroid.remove(); // ✅ remove card from DOM
          } catch (err) {
            console.log("🔴 error:", err.message);
            alert(err.message);
          }
        });
      }
    } catch(e) {
      console.log("token decode error:", e);
    }
  }

  return card;
}
      async function loadPosts() {
        feed.innerHTML =
          '<p class="loading"><i class="bi bi-arrow-repeat"></i> Loading posts...</p>';
        try {
          const res = await fetch("/posts");
          const posts = await res.json();
          feed.innerHTML = "";
          if (!posts.length) {
            feed.innerHTML =
              '<div class="empty-feed"><i class="bi bi-journal-x"></i>No posts yet. Be the first!</div>';
            return;
          }
          posts.forEach((p) => feed.appendChild(renderPost(p)));
        } catch {
          feed.innerHTML =
            '<p class="loading">Could not load posts. Make sure the server is running.</p>';
        }
      }

      loadPosts();
    </script>

    <!-- Hidden blueprint — place this anywhere, e.g. before </body> -->
<template id="post-template">
  <div class="polaroid position-relative">

    <!-- ✅ Dropdown menu (only shown to post owner) -->
