    // ── Load Feed ──
    function renderPost(post) {
      const div = document.createElement('div');
      div.className = 'post-card';
      div.innerHTML = `
        <div class="post-header">
          <div class="avatar">J</div>
          <div>
            <div class="fw-semibold" style="font-size:.9rem;line-height:1.2;">John Doe</div>
            <div class="text-muted" style="font-size:.75rem;">${new Date(post.createdAt).toLocaleString()}</div>
          </div>
        </div>
        ${post.caption ? `<div class="post-body">${post.caption}</div>` : ''}
        ${post.imageUrl ? `<img src="${post.imageUrl}" alt="Post image"/>` : ''}
        <div class="post-footer">
          <button><i class="bi bi-hand-thumbs-up"></i> Like</button>
          <button><i class="bi bi-chat"></i> Comment</button>
          <button><i class="bi bi-share"></i> Share</button>
        </div>`;
      return div;
    }